import asyncio
import os
from dotenv import load_dotenv
import certifi
from motor.motor_asyncio import AsyncIOMotorClient

load_dotenv()
MONGO_DETAILS = os.getenv("MONGO_DETAILS")

async def promote_to_admin():
    client = AsyncIOMotorClient(MONGO_DETAILS, tlsCAFile=certifi.where())
    database = client.codealert
    
    # Yahan us user ka email daalo jise admin banana hai
    target_email = "revant0501@gmail.com" 
    
    result = await database.users.update_one(
        {"email": target_email},
        {"$set": {"is_admin": True}}
    )
    
    if result.matched_count > 0:
        print(f"✅ Success: {target_email} ab ADMIN ban gaya hai!")
    else:
        print("❌ Error: Koi user nahi mila is email se.")

asyncio.run(promote_to_admin())
